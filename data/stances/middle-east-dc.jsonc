{
  "id": "middle-east-dc",
  "name": "Middle East data center",
  "desc": "Strategic compute-location bargain: Gulf states offer power, land, capital, and sovereign-wealth investment in exchange for frontier compute access, creating dependencies that outlast model generations and expose both sides to host-jurisdiction risk.",
  "picks": {
    "Capability Class": {
      "value": "Strategic",
      "memo": "Middle East data-center deals are strategic sovereignty plays, not routine hosting contracts.",
      "detail": "Gulf states seek AI compute access as a strategic national-capability investment. The data centers are framed as sovereign infrastructure rather than commercial real estate. Strategic capability positioning drives the scale and terms of the investment. These are state-level bets on AI as a national-competitiveness lever."
    },
    "Domain Breadth": {
      "value": "Multi-domain",
      "memo": "Strategic compute locations serve multi-domain AI workloads spanning government, enterprise, and consumer applications.",
      "detail": "Data centers in the Gulf serve diverse national AI ambitions across government, energy, finance, and healthcare. Multi-domain breadth reflects sovereign AI strategies covering entire national economies. The compute bargain is not domain-specific but infrastructure-level. Multi-domain scope justifies the strategic-build investment scale."
    },
    "Capability Trajectory": {
