    },
    "Switching Cost": {
      "value": "Contractual friction",
      "memo": "UK AI switching costs are moderate contractual friction from integration and migration, matching the US commercial default.",
      "detail": "Switching between AI providers in the UK involves the same integration and migration costs as globally. No UK regulation reduces or increases these switching costs relative to other markets. Contractual friction sustains incumbent relationships without creating hard lock-in. The switching-cost level is inherited from the global cloud AI market."
    },
    "Exit": {
      "value": "Capability entangled",
      "memo": "UK exit from AI training relationships faces capability entanglement despite strong copyright: termination does not remove trained capability.",
      "detail": "If a UK rights holder terminates a training license, the trained capability remains in model weights. This is the core tension: strong rights language cannot produce clean exit from neural-network training. No UK legal or technical mechanism extracts specific contributions from trained models. Exit is capability-entangled regardless of the strength of the underlying rights."
    },
    "Acceptance Basis": {
      "value": "Hybrid",
      "memo": "Strong rights-holder language demands process, but practical enforcement and infrastructure sit closer to outcome-acceptance.",
      "detail": "UK copyright and data protection frameworks articulate process requirements that mirror EU standards in aspiration. Practical enforcement capacity and political appetite for innovation create an outcome-tolerant gap. Rights holders demand process legitimacy while deployers operate on outcome evidence. The tension runs through the legitimacy basis, creating regulatory uncertainty on both sides."
    }
  }
}
