{
  "id": "rag",
  "name": "Enterprise RAG",
  "desc": "Inference-time data use with clean exit: retrieval-augmented generation keeps enterprise data separate from model weights, preserving optionality through architectural separation rather than contractual protection.",
  "picks": {
    "Capability Class": {
      "value": "Tool-grade",
      "memo": "Enterprise RAG is tool-grade: bounded to a specific business corpus rather than operating at frontier general capability.",
      "detail": "RAG systems answer questions about a specific enterprise knowledge base. The capability is constrained by the quality and scope of the retrieval corpus. Tool-grade reflects the bounded, purpose-specific nature of the deployment. RAG is valuable for what it does, not for frontier general capability."
    },
    "Domain Breadth": {
      "value": "Single-domain",
      "memo": "Enterprise RAG is single-domain by design: scoped to a specific business corpus for focused, reliable retrieval.",
      "detail": "Each RAG deployment is configured for a specific enterprise knowledge domain. Single-domain scoping improves retrieval precision and answer relevance. The domain limitation is a feature that keeps the system manageable and auditable. Broad multi-domain RAG sacrifices the precision that makes the architecture valuable."
    },
    "Capability Trajectory": {
      "value": "Incremental",
      "memo": "Enterprise RAG capability improves incrementally through corpus expansion, embedding optimization, and model upgrades.",
      "detail": "RAG quality improves through better retrieval, larger corpora, and upgraded language models. The improvement is incremental and measurable through relevance and accuracy metrics. No discontinuous capability jump characterizes RAG advancement. Incremental improvement is manageable and governable for enterprise deployment."
    },
    "Research Automation": {
      "value": "Human-led",
      "memo": "Enterprise RAG development is human-led, with engineers tuning retrieval, embeddings, and prompts rather than automating research.",
      "detail": "RAG pipeline development involves human engineering of chunking, embedding, and retrieval strategies. No automated research loop drives RAG system improvement independent of human direction. Human-led development reflects the engineering nature of RAG optimization. The human-led approach keeps the system within standard enterprise IT governance."
    },
    "Unhobbling": {
      "value": "Tool-using",
      "memo": "Enterprise RAG is a tool-using system: the model uses retrieval as a bounded tool to access enterprise knowledge.",
      "detail": "Retrieval gives the language model structured access to a document corpus. The tool-use pattern is bounded: the model queries an index and receives relevant passages. This is tool-using rather than agentic because the model does not autonomously decide what to retrieve. The bounded tool-use pattern keeps the system within manageable control boundaries."
    },
    "Replication Scale": {
      "value": "Many copies",
      "memo": "Enterprise RAG deploys many instances across departments and use cases, creating controlled replication within the organization.",
      "detail": "Enterprise rollout typically creates multiple RAG instances for different departments or knowledge bases. Each instance serves many concurrent users within the organization. Many-copies deployment within enterprise boundaries provides controlled scale. The replication is managed and auditable unlike population-scale consumer deployment."
    },
    "Operating Speed": {
      "value": "Faster-than-human",
      "memo": "Enterprise RAG delivers answers faster than human research through instant retrieval and synthesis of relevant enterprise documents.",
      "detail": "RAG systems retrieve and synthesize information in seconds compared to minutes or hours of manual research. The speed advantage drives the productivity value proposition for enterprise adoption. Faster-than-human operation transforms knowledge-work efficiency. The speed benefit is most pronounced for complex queries spanning many documents."
    },
    "Physical World Extension": {
      "value": "Cognitive-only",
      "memo": "Enterprise RAG is purely cognitive: retrieving and synthesizing text information without any physical-world actuation.",
      "detail": "RAG systems produce text outputs from text inputs without physical-world interaction. No robotics, sensor, or actuation component is involved. Cognitive-only operation keeps the system within standard information-system governance. The absence of physical extension simplifies risk management."
    },
    "Role": {
      "value": "Assistant",
      "memo": "Enterprise RAG serves as an assistant that produces reviewable answers, not a copilot that participates in work execution.",
      "detail": "RAG systems answer questions and produce summaries for human review and decision-making. The system does not own workstreams or execute consequential actions. The assistant role preserves human agency over decisions based on RAG outputs. Role clarity simplifies liability and governance for enterprise deployment."
    },
    "Actuation": {
      "value": "Informational",
      "memo": "Enterprise RAG actuation is purely informational: the system provides information without performing any digital or physical action.",
      "detail": "RAG outputs are text answers and document summaries, not system actions or state changes. No API call, file modification, or external communication results from RAG operation. Informational actuation keeps the system within the lowest-risk activity category. The informational-only channel simplifies security and compliance governance."
    },
    "Autonomy": {
      "value": "Stateless task",
      "memo": "Enterprise RAG executes stateless query-answer tasks without persistent goals, memory, or autonomous objective pursuit.",
      "detail": "Each RAG query is a stateless task: question in, answer out, no persistent state. The system does not accumulate context, pursue objectives, or remember previous interactions. Stateless operation prevents goal drift and unintended capability accumulation. The stateless design is a deliberate architectural choice for governance simplicity."
    },
    "Delegated Authority": {
      "value": "Recommend only",
      "memo": "RAG recommends answers and surfaces relevant information but has no delegated authority to act on the user's behalf or make binding decisions.",
      "detail": "The system retrieves and recommends. The user retains all decision authority. Recommend-only delegation means the enterprise does not need to trust the model with binding actions. Recommendation quality depends on retrieval accuracy, which depends on corpus quality. The authority boundary is clear: the system informs, the human decides."
    },
    "Tool Access": {
      "value": "Single bounded tool",
      "memo": "Enterprise RAG accesses a single bounded tool: the vector-search retrieval index over the enterprise corpus.",
      "detail": "The RAG system's only tool is the retrieval interface to the document index. No broader toolchain connects the system to enterprise systems or external services. Single-tool access limits the blast radius of any system failure or misuse. The bounded tool scope is a security feature of the RAG architecture."
    },
    "Response / Intervention Capability": {
      "value": "Defined escalation",
      "memo": "Enterprise RAG has defined escalation: clear procedures for handling incorrect, harmful, or confidential-data-leaking outputs.",
      "detail": "Enterprise IT governance provides defined procedures for system incidents. RAG-specific escalation addresses retrieval failures, hallucination, and data-leakage events. Defined escalation is part of standard enterprise application deployment. The escalation framework is inherited from enterprise IT rather than AI-specific governance."
    },
    "Command Actor": {
      "value": "Enterprise",
      "memo": "The enterprise controls RAG deployment, data access, and governance through standard IT management authority.",
      "detail": "Enterprise IT departments determine RAG deployment scope, data access, and user authorization. No external party controls the enterprise's RAG system configuration. The enterprise command structure applies standard IT governance to AI deployment. Command authority is clear and aligned with existing organizational structures."
    },
    "Decision Tempo": {
      "value": "Product cycle",
      "memo": "Enterprise RAG deployment follows standard product and IT deployment cycles rather than crisis or competitive tempo.",
      "detail": "RAG rollout follows enterprise IT change-management and deployment procedures. Updates to the corpus, embeddings, and model follow planned release cycles. Product-cycle tempo provides adequate governance for enterprise RAG systems. No competitive urgency forces faster deployment than standard IT processes allow."
    },
    "Tradeoff Authority": {
      "value": "Product team",
      "memo": "Enterprise product teams make RAG deployment tradeoffs between accuracy, coverage, cost, and data-access scope.",
      "detail": "Product and IT teams determine which corpora to index, what models to use, and how to configure retrieval. Tradeoffs between answer quality and compute cost are standard product decisions. No external safety body reviews enterprise RAG deployment decisions. Product-team authority reflects the low-risk nature of informational RAG systems."
    },
    "Permission": {
      "value": "Conditional",
      "memo": "Enterprise RAG data access is conditional on internal data-governance policies and external licensing terms for third-party content.",
      "detail": "Access to enterprise knowledge bases requires authorization through data-governance policies. Third-party content in the corpus may carry licensing terms restricting AI use. Conditional permission reflects the data-governance discipline needed for enterprise deployment. Permission management is a standard enterprise data-governance function."
    },
    "Regulatory Posture": {
      "value": "Conditional",
      "memo": "Enterprise RAG operates under conditional regulatory requirements for data protection, sector-specific rules, and emerging AI regulations.",
      "detail": "GDPR, sector-specific regulations, and emerging AI rules create conditional deployment requirements. Financial-services and healthcare RAG face additional sector-specific obligations. The conditional posture reflects the regulatory environment for enterprise data processing. Compliance management is a standard enterprise function rather than an AI-specific challenge."
    },
    "Data Availability": {
      "value": "Proprietary owned",
      "memo": "Enterprise RAG operates on proprietary enterprise data owned and controlled by the deploying organization.",
      "detail": "The retrieval corpus consists of enterprise-owned documents, knowledge bases, and internal content. Proprietary data ownership provides clear rights to use the content for RAG. No external licensing negotiation is needed for internally generated content. Proprietary ownership simplifies the data-rights architecture compared to training-data acquisition."
    },
    "Provenance": {
      "value": "Verifiable",
      "memo": "Enterprise RAG provides verifiable provenance: every answer can be traced to specific source documents in the retrieval corpus.",
      "detail": "RAG architectures retrieve specific document chunks that ground the model's response. Source citations provide verifiable provenance for every generated answer. Users can check the original documents to verify accuracy and context. Verifiable provenance is a core advantage of RAG over pure generation."
    },
    "Model-Weight Rights": {
      "value": "Hosted only",
      "memo": "Enterprise RAG uses hosted models through API access, keeping model weights under the provider's control.",
      "detail": "The language model component typically runs as a hosted API from an external provider. Enterprise data passes through the model at inference time without modifying weights. Hosted-only access simplifies the rights picture: the enterprise owns the data, the provider owns the model. The clean separation between data and model is the architectural foundation of RAG governance."
    },
    "Territory": {
      "value": "Domestic",
      "memo": "Enterprise RAG typically operates domestically, with data and processing staying within the deploying organization's home jurisdiction.",
      "detail": "Enterprise data-governance policies generally keep sensitive content within domestic borders. Cloud-region selection ensures processing occurs in the appropriate jurisdiction. Domestic territory simplifies regulatory compliance for enterprise RAG. Cross-border RAG raises additional data-transfer considerations addressed through cloud-region choices."
    },
    "Data Subject Exposure": {
      "value": "Ordinary personal data",
      "memo": "Enterprise RAG corpora frequently contain ordinary personal data in documents, emails, and records requiring privacy-compliant handling.",
      "detail": "Enterprise knowledge bases include employee names, client details, and business correspondence. Personal-data presence triggers data-protection obligations for the RAG system. Privacy-compliant handling requires access controls, purpose limitation, and potential anonymization. Personal-data exposure is the primary privacy concern for enterprise RAG deployment."
    },
    "Data Sensitivity": {
      "value": "Commercial confidential",
      "memo": "Enterprise RAG processes commercially confidential business information including strategy, financials, and client matters.",
      "detail": "Enterprise knowledge bases contain trade secrets, financial projections, and strategic plans. Client-matter information in professional-services RAG carries confidentiality obligations. The commercial-confidential sensitivity level requires enhanced security and access controls. Data sensitivity drives security requirements above standard consumer AI deployment."
    },
    "Control Exposure": {
      "value": "No control issue",
      "memo": "Enterprise RAG deployment sits well below export-control or dual-use thresholds for standard commercial applications.",
      "detail": "Standard enterprise RAG deployments do not trigger export-control or dual-use concerns. The informational nature and bounded scope keep the system outside control-relevant categories. No control exposure means no additional compliance burden from technology-transfer regulations. This simplicity is a deployment advantage of the RAG architecture."
    },
    "Processing Mode": {
      "value": "Inference",
      "memo": "Enterprise RAG operates entirely at inference time: enterprise data is retrieved and processed without any model training.",
      "detail": "RAG's defining characteristic is inference-time data use rather than training-time incorporation. Enterprise data is retrieved, passed to the model, and processed without modifying weights. The inference-only processing mode is what creates the clean separation between data and model. Inference-time use preserves the optionality that training-time use destroys."
    },
    "Derivation": {
      "value": "Direct output",
      "memo": "Enterprise RAG produces direct outputs from retrieved documents without creating recursive derivation chains or feedback loops.",
      "detail": "RAG answers are generated from retrieved passages without feeding back into model training. No recursive derivation occurs: outputs are consumed by users, not by the model. Direct-output processing avoids the exhaust-capture dynamics of training-based systems. The absence of recursive derivation simplifies data-governance and value-allocation questions."
    },
    "Retention / Persistence": {
      "value": "Ephemeral/stateless",
      "memo": "Enterprise RAG processing is ephemeral: queries and responses are processed without persistent retention in the model or inference system.",
      "detail": "Each RAG query is processed and discarded without persistent storage in the model. No user data accumulates in the inference system across queries. Ephemeral processing supports data-minimization principles and simplifies compliance. The stateless design is a governance feature that training-based systems cannot replicate."
    },
