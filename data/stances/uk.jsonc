{
  "id": "uk",
  "name": "UK",
  "desc": "Structural tension: strong rights-holder language and copyright posture sit on top of US-style cloud infrastructure, enforcement gaps, and unresolved exit — the posture pulls in two directions.",
  "picks": {
    "Capability Class": {
      "value": "Frontier",
      "memo": "UK copyright and regulatory posture is most consequential for frontier-scale training where data exposure is highest.",
      "detail": "The UK's rights-holder protections matter because frontier training consumes internet-scale copyrighted data. Smaller or domain-specific models can navigate licensing more easily. The frontier focus is where the structural tension becomes visible. Strong rights language meets practical inability to enforce against offshore frontier labs."
    },
    "Domain Breadth": {
      "value": "Multi-domain",
      "memo": "UK copyright protections apply across domains, creating broad friction for any multi-domain training corpus.",
      "detail": "Copyright applies uniformly across text, code, music, and visual domains in the UK. No sector-specific exemption narrows the rights-holder protection to particular content types. This multi-domain scope means any broad training corpus faces UK rights challenges. The breadth amplifies the tension between legal ambition and practical enforcement."
    },
    "Capability Trajectory": {
      "value": "Incremental",
      "memo": "Unresolved rights and regulatory uncertainty slow UK AI capability growth toward cautious, incremental deployment.",
      "detail": "Legal uncertainty around training rights discourages bold investment in UK-based AI capability. Companies proceed cautiously, preferring incremental feature additions over large-scale training runs. This trajectory is not a technology constraint but a regulatory-posture consequence. Incremental progress is the rational response to unresolved rights frameworks."
    },
    "Research Automation": {
      "value": "AI-assisted",
