{
  "id": "chinese-oss",
  "name": "Chinese OSS model",
  "desc": "Open-weight diffusion as competitive strategy: releasing capable model weights compresses rivals' leads, creates adoption dependency, introduces provenance and supply-chain questions, and shifts the competitive landscape without requiring traditional export channels.",
  "picks": {
    "Capability Class": {
      "value": "Frontier",
      "memo": "Chinese open-weight models like DeepSeek and Qwen operate near the frontier, making their open release strategically significant.",
      "detail": "Models released at near-frontier capability levels create genuine competitive pressure on Western labs. Open-weight release at this capability level has different strategic implications than releasing weaker models. The frontier adjacency is what makes Chinese OSS models a proliferation event rather than just a community contribution. Capability level determines the strategic significance of the release."
    },
    "Domain Breadth": {
      "value": "General",
      "memo": "Chinese open-weight models are general-purpose, applicable across every domain, maximizing the breadth of strategic impact.",
      "detail": "DeepSeek, Qwen, and similar models cover language, code, reasoning, and vision domains. General-purpose breadth means the proliferation affects every sector simultaneously. No domain limitation constrains the competitive impact of the open release. The broad applicability amplifies both adoption and strategic concern."
    },
    "Capability Trajectory": {
      "value": "Compressed",
      "memo": "Open-weight release compresses capability timelines for recipients, providing frontier-adjacent capability without the years of R&D investment.",
      "detail": "Organizations that adopt Chinese open-weight models skip years of model development. The compressed trajectory benefits adopters at the expense of labs that invested in original development. Each new open-weight release further compresses the strategic lead of Western frontier labs. Compression through open release is a qualitatively different competitive dynamic from independent development."
    },
    "Research Automation": {
      "value": "AI-assisted",
      "memo": "Chinese AI labs use their own models to accelerate research, creating improvement loops similar to US frontier labs.",
      "detail": "DeepSeek and other Chinese labs use AI assistance in their research processes. The AI-assisted research loop accelerates capability development on both sides of the geopolitical divide. Chinese labs' research automation matches the capability of their US counterparts. The reciprocal improvement loop drives the pace of competitive development."
    },
    "Unhobbling": {
      "value": "Agentic",
      "memo": "Chinese open-weight models support agentic deployment, meaning recipients can build autonomous agents without developing their own base models.",
      "detail": "Open-weight models with tool use and code execution capabilities enable agentic applications. Recipients can build autonomous agent systems using Chinese models as the foundation. Agentic capability in open-weight models creates the broadest possible deployment surface. The unhobbling level determines the range of downstream applications."
    },
    "Replication Scale": {
      "value": "Population-scale",
      "memo": "Open-weight release enables population-scale deployment as anyone can run the model, creating unconstrained replication.",
      "detail": "Open weights remove all supply-side constraints on deployment scale. Any organization with sufficient compute can serve the model to unlimited users. Population-scale replication is inherent to the open-weight distribution model. The scale of potential deployment far exceeds API-controlled distribution."
    },
    "Operating Speed": {
      "value": "Faster-than-human",
      "memo": "Chinese open-weight models operate at the same faster-than-human speed as any GPU-deployed model.",
      "detail": "Inference speed is hardware-determined, not model-origin-determined. Open-weight models run at identical speeds to closed models on the same hardware. Faster-than-human operation is available to every recipient of the open weights. The speed capability is independent of the model's origin."
    },
    "Physical World Extension": {
      "value": "Cognitive-only",
      "memo": "Chinese open-weight models are cognitive-only, focused on language, code, and reasoning rather than physical actuation.",
      "detail": "Current open-weight releases target cognitive capabilities rather than robotics or physical systems. The cognitive focus keeps the proliferation concern in the information and digital-action domains. Physical-world AI extension from Chinese labs exists but follows separate distribution channels. Cognitive-only positioning reflects the current release strategy."
    },
    "Role": {
      "value": "Agent",
      "memo": "Chinese open-weight models enable agent-role deployment, with recipients building autonomous systems using the released weights.",
      "detail": "Open weights with sufficient capability support autonomous agent construction. Recipients are not limited to assistant or copilot roles by the model's capabilities. The agent-capable role reflects the frontier-adjacent capability of recent Chinese releases. Agent-enabling capability maximizes the strategic impact of the open-weight proliferation."
    },
    "Actuation": {
      "value": "Digital action",
      "memo": "Chinese open-weight models support digital action through code execution and tool use, enabling consequential system interactions.",
      "detail": "Models with code generation and tool-call capabilities enable digital actions by downstream deployers. The digital-action channel is available to every recipient of the open weights. No gating mechanism restricts what digital actions deployers build. The actuation capability is part of the proliferated package."
    },
    "Autonomy": {
      "value": "Human-out-of-loop",
      "memo": "Open-weight models can be deployed without any human oversight, as recipients control deployment configuration.",
      "detail": "Open-weight recipients can remove safety filters and deploy models without human oversight. No technical mechanism prevents human-out-of-loop deployment of open-weight models. The autonomy level is determined by the deployer rather than the model provider. Human-out-of-loop potential is inherent to open-weight distribution."
    },
    "Delegated Authority": {
      "value": "Operational mandate",
      "memo": "Recipients can configure Chinese open-weight models with operational mandates, delegating consequential authority without provider oversight.",
      "detail": "Open-weight deployment allows recipients to grant models whatever authority they choose. No model-provider governance constrains the delegated authority in open-weight deployment. Operational mandates can include financial transactions, system modifications, and communication authority. The delegation potential is determined by the deployer, not the model source."
    },
    "Tool Access": {
      "value": "Broad toolchain",
      "memo": "Open-weight models can be connected to any toolchain the deployer chooses, without provider-imposed tool restrictions.",
      "detail": "Recipients integrate open-weight models with whatever tools their use case requires. No provider-side gating limits tool access for open-weight deployments. The broad-toolchain potential includes sensitive systems that API providers would restrict. Tool access breadth is limited only by the deployer's choices."
    },
    "Response / Intervention Capability": {
      "value": "No effective override",
      "memo": "Once weights are released, no effective override exists: the model provider cannot intervene in downstream deployments.",
      "detail": "Open-weight release permanently transfers model capability outside provider control. No kill switch, update mechanism, or intervention path reaches independently deployed instances. The model provider has no knowledge of or authority over downstream deployments. Absence of effective override is the fundamental governance challenge of open-weight release."
    },
    "Command Actor": {
      "value": "State/coalition",
      "memo": "Chinese AI labs operate under state-level strategic direction, with open-weight releases reflecting national-competitive strategy.",
      "detail": "Chinese AI lab decisions are influenced by state industrial policy and competitive strategy. Open-weight release decisions reflect strategic calculations about eroding Western leads. State direction does not mean every release is directly ordered but the strategic context is national. The command actor for the release strategy operates at state level."
    },
    "Decision Tempo": {
      "value": "Crisis tempo",
      "memo": "Chinese open-weight release timing responds to competitive crisis dynamics, with releases timed to disrupt Western lab advantages.",
      "detail": "Release timing often correlates with Western lab announcements or competitive developments. The rapid release cadence reflects competitive urgency rather than product-cycle planning. Crisis-tempo decisions prioritize strategic impact over incremental product refinement. The decision speed reflects the race-dynamic nature of Chinese AI competition."
    },
    "Tradeoff Authority": {
      "value": "National command",
      "memo": "Strategic tradeoffs about Chinese AI capability release involve national-level authorities balancing competitive advantage against capability diffusion.",
      "detail": "Decisions about whether to release frontier-adjacent capability openly involve strategic national considerations. National-command authority balances the competitive benefit of eroding Western leads against the risk of empowering adversaries. The tradeoff calculus operates at a level above individual lab or product-team decisions. National-command involvement reflects the strategic significance of open-weight release."
    },
    "Permission": {
      "value": "Broad",
      "memo": "Chinese open-weight models are released with broad permission terms, enabling nearly unrestricted commercial and research use.",
      "detail": "Open-weight licenses like DeepSeek's and Qwen's impose minimal use restrictions. Broad permission maximizes adoption and competitive disruption. The permissive licensing is a strategic choice to maximize the models' impact. Broad permission ensures the widest possible distribution and integration."
    },
    "Regulatory Posture": {
      "value": "Mandated open",
      "memo": "The open-weight release strategy effectively mandates openness, creating a de facto open-access competitive environment.",
      "detail": "Once weights are released openly, the competitive environment shifts toward open access. Other labs face pressure to open their own models or compete against free alternatives. The mandated-open posture is strategic: it undermines the business models of closed-model competitors. Open release changes the industry structure rather than just individual competitive positions."
    },
    "Data Availability": {
      "value": "Open/available",
      "memo": "Chinese open-weight models were trained on broadly available data with minimal disclosed provenance constraints.",
      "detail": "Training data for Chinese open-weight models includes web-crawled content, code repositories, and available datasets. Data-access constraints in China differ from Western jurisdictions, potentially enabling broader scraping. The open-available data posture supports the low-cost training that enables open-weight release. Data availability within China's regulatory framework supports competitive model development."
    },
    "Provenance": {
      "value": "Unknown",
      "memo": "Training data provenance for Chinese open-weight models is largely unknown: no comprehensive disclosure reveals data sources or processing.",
      "detail": "Chinese labs provide limited disclosure about training data composition and sources. The unknown provenance creates security and compliance concerns for institutional adopters. No independent verification mechanism confirms or denies specific data-source claims. Unknown provenance is one of the primary risk factors for Chinese open-weight adoption."
    },
    "Model-Weight Rights": {
      "value": "Open-stack",
      "memo": "Chinese open-weight models provide open-stack access: weights are freely downloadable, inspectable, and modifiable.",
      "detail": "Open-weight release provides the most permissive form of model access available. Recipients can inspect, modify, fine-tune, and redistribute the weights. Open-stack access is the delivery mechanism for the proliferation strategy. The weight-access model is maximally permissive by design."
    },
    "Territory": {
      "value": "Cross-border",
      "memo": "Chinese open-weight models cross borders instantly through internet distribution, reaching every jurisdiction without physical transfer.",
      "detail": "Model weights download globally through Hugging Face, GitHub, and direct distribution. Cross-border distribution occurs without the physical controls that apply to GPU exports. No customs, export license, or physical logistics gate the territory crossing. The cross-border nature of digital weight distribution is what makes open release a proliferation mechanism."
    },
