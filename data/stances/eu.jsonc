    "Revenue Dependency": {
      "value": "Experimental",
      "memo": "European AI remains at experimental revenue dependency, enhancing existing business rather than constituting core business lines.",
      "detail": "Most European companies treat AI as an experimental enhancement to existing operations. AI revenue is rarely a standalone business line for European firms. This experimental dependency means AI failure would be inconvenient but not existential. The early revenue stage reflects the EU's later adoption curve."
    },
    "Switching Cost": {
      "value": "Low",
      "memo": "EU portability rules and multi-provider strategy keep switching costs low, preserving buyer optionality across AI services.",
      "detail": "Data portability rights and interoperability requirements reduce provider lock-in. Multi-provider sourcing and API standardization further lower switching friction. Low switching costs are a policy objective of the EU digital-market framework. This preserves competition and buyer power in the AI service market."
    },
    "Exit": {
      "value": "Exportable",
      "memo": "EU data governance creates exportable exit conditions, with data portability rights enabling cleaner separation from AI providers.",
      "detail": "GDPR data portability rights allow individuals and organizations to retrieve their data from AI services. The inference-centric processing mode avoids the weight-entanglement problem that makes US exits messy. This creates a cleaner exit path than the capability-entangled US default. Exportable exit is a designed feature of the EU governance framework."
    },
    "Acceptance Basis": {
      "value": "Process-required",
      "memo": "GDPR right to explanation and AI Act transparency obligations demand articulable process as the basis for acceptance.",
      "detail": "The AI Act mandates risk assessments, conformity procedures, and human oversight documentation before deployment. GDPR requires data-processing justification that goes beyond outcome quality. Regulatory posture demands that the deployer can explain how the system works, not just that it works. Process legitimacy is the price of market access in the EU."
    }
  }
}
