{
  "id": "tsmc-asml",
  "name": "TSMC / ASML chokepoint",
  "desc": "The invisible foundation: advanced foundry fabrication and EUV lithography sit below the visible compute layer, creating chokepoints where a single company's capacity determines who can build frontier AI hardware.",
  "picks": {
    "Capability Class": {
      "value": "Strategic",
      "memo": "Control of advanced chip fabrication is a strategic-sovereignty issue, not just a commercial capability question.",
      "detail": "TSMC's ability to fabricate leading-edge chips determines which nations can produce frontier AI hardware. ASML's EUV lithography tools are prerequisites for advanced fabrication. Strategic capability at this layer means that foundry access shapes national AI capacity. No AI frontier exists without access to these upstream chokepoints."
    },
    "Domain Breadth": {
      "value": "General",
      "memo": "Foundry and lithography chokepoints affect all AI domains because all frontier accelerators require leading-edge fabrication.",
      "detail": "Every AI accelerator from Nvidia GPUs to Google TPUs to Apple neural engines uses TSMC fabrication. No domain-specific alternative bypasses the foundry chokepoint. The general breadth means these chokepoints constrain the entire AI ecosystem simultaneously. Domain-agnostic impact amplifies the strategic significance."
    },
    "Capability Trajectory": {
      "value": "Compressed",
      "memo": "Each foundry process-node advancement compresses AI capability timelines by enabling more powerful accelerators.",
      "detail": "TSMC's transition from 5nm to 3nm to 2nm enables successive generations of more powerful AI chips. Each node advancement allows more transistors, more compute, and more capable models. The foundry's process roadmap sets the pace of AI hardware improvement. Compressed foundry timelines translate directly into compressed AI capability advancement."
    },
    "Research Automation": {
      "value": "Human-led",
      "memo": "Semiconductor fabrication and lithography R&D remain human-led, with process development requiring deep materials and physics expertise.",
      "detail": "Leading-edge process development at TSMC involves years of human-directed materials science and engineering. ASML's EUV development required decades of human-led optical and systems engineering. AI tools assist with design optimization but do not drive foundry research direction. The physical nature of semiconductor manufacturing limits automation of the R&D process."
    },
    "Unhobbling": {
      "value": "Chatbot",
      "memo": "Foundry and lithography companies are not AI systems; the minimal unhobbling level reflects their infrastructure-provider nature.",
      "detail": "TSMC and ASML provide physical manufacturing infrastructure rather than AI services. No AI unhobbling concept applies to semiconductor fabrication equipment or processes. The chatbot default is the minimal applicable position for a non-AI system. The stance describes a supply-chain position rather than an AI deployment."
    },
    "Replication Scale": {
      "value": "Single instance",
      "memo": "Each advanced foundry fab is a unique facility; there are only a handful of leading-edge fabs worldwide.",
      "detail": "TSMC operates a small number of leading-edge fabs in Taiwan and Arizona. Each fab is a multi-billion-dollar facility that cannot be quickly replicated. ASML produces EUV machines in single-digit annual quantities. The single-instance scale reflects the extreme concentration of advanced semiconductor manufacturing."
    },
    "Operating Speed": {
      "value": "Human-speed",
      "memo": "Fab construction, process development, and tool installation operate at human industrial timescales measured in years.",
      "detail": "Building a new leading-edge fab takes three to five years from groundbreaking to production. Process qualification requires months of engineering iteration. EUV tool installation and qualification takes months per machine. Human-speed operation reflects the physical nature of semiconductor manufacturing."
    },
    "Physical World Extension": {
      "value": "Automated production",
      "memo": "TSMC fabs and ASML EUV tools are automated production systems operating at the most extreme precision in industrial manufacturing.",
      "detail": "EUV lithography requires positioning precision measured in fractions of nanometers. Fab operations are heavily automated with robotic wafer handling and process control. The manufacturing precision exceeds any other human industrial process. Automated production at this scale is the ultimate physical-world extension of engineering capability."
    },
    "Role": {
      "value": "Tool",
      "memo": "TSMC and ASML are essential tools in the AI supply chain: infrastructure providers that every AI chip depends on.",
      "detail": "Foundries and lithography vendors are tools used by chip designers to create AI accelerators. They do not deploy AI systems or make AI-driven decisions for end users. The tool role is maximally strategic because the entire AI hardware layer depends on it. Infrastructure-tool power at this depth exceeds any application-layer influence."
    },
    "Actuation": {
      "value": "Physical/kinetic",
      "memo": "Foundry fabrication and EUV lithography involve physical actuation at nanometer precision, manufacturing the physical objects AI runs on.",
      "detail": "EUV lithography uses extreme-ultraviolet light to pattern silicon wafers at nanometer scale. Physical and chemical processes deposit, etch, and connect billions of transistors per chip. The actuation is physical manufacturing rather than digital computation. Physical-kinetic actuation at this precision level is globally unique."
    },
    "Autonomy": {
      "value": "Stateless task",
      "memo": "Fab operations execute manufacturing tasks without autonomous goal pursuit; each wafer lot is a discrete production job.",
      "detail": "Manufacturing processes execute predefined recipes without autonomous decision-making. Each production lot follows specified process parameters set by engineers. Fab operations have no autonomous goals or self-directed behavior. Stateless task execution describes the manufacturing process accurately."
    },
    "Delegated Authority": {
      "value": "None",
      "memo": "No delegated authority: fabs execute manufacturing orders from chip-design customers without binding decisions.",
      "detail": "TSMC fabricates chips according to customer designs without making design or deployment decisions. No foundry authority extends beyond manufacturing execution. Customer designs determine what the fab produces. None is the correct delegation level for contract manufacturing."
    },
    "Tool Access": {
      "value": "Privileged tools",
      "memo": "ASML EUV tools and TSMC process technology are privileged: restricted access to the most sensitive manufacturing capability in the world.",
      "detail": "EUV lithography tools are export-controlled and available only to approved customers. TSMC's most advanced process nodes are allocated to priority customers under long-term agreements. Access to these privileged tools determines who can build frontier AI chips. The restricted access is enforced by both commercial allocation and government export controls."
    },
    "Response / Intervention Capability": {
      "value": "War-room protocol",
      "memo": "Disruption to TSMC or ASML operations requires war-room-level crisis coordination involving companies, governments, and military.",
      "detail": "TSMC fab disruption would trigger global semiconductor supply-chain crisis response. Earthquake, military threat, or equipment failure at key facilities require coordinated multinational response. ASML EUV tool production disruption would halt leading-edge chip manufacturing globally. War-room protocols reflect the strategic criticality of these chokepoints."
    },
    "Command Actor": {
      "value": "State/coalition",
      "memo": "TSMC and ASML operate under state and coalition command influence through export controls, investment screening, and strategic industrial policy.",
      "detail": "US export controls on ASML EUV sales to China demonstrate state-level command over these chokepoints. Taiwan's strategic management of TSMC reflects state influence on corporate decisions. Dutch government coordination with US on ASML export policy shows coalition governance. State-coalition command reflects the national-security significance of these companies."
    },
    "Decision Tempo": {
      "value": "Product cycle",
      "memo": "Foundry and lithography decisions follow multi-year product cycles: new process nodes and EUV generations take years to develop.",
      "detail": "TSMC process-node development spans three to five years per generation. ASML EUV tool development extends over decade-long timescales. Decision tempo is measured in years rather than quarters. The long product cycles mean today's decisions shape capability five to ten years out."
    },
    "Tradeoff Authority": {
      "value": "National command",
      "memo": "Strategic decisions about TSMC and ASML — who gets access, where fabs are built — involve national-command authority.",
      "detail": "Export-control decisions about EUV sales to China are made at national-government level. TSMC fab location decisions in Arizona involve US government industrial policy. Taiwan government strategic management of TSMC reflects national-security considerations. National-command authority applies to the most consequential chokepoint decisions."
    },
    "Permission": {
      "value": "Conditional",
      "memo": "Access to TSMC fabrication and ASML tools is conditional on export-control compliance, customer qualification, and allocation agreements.",
      "detail": "Not every chip designer can access TSMC's most advanced nodes; allocation requires qualification and commitment. ASML EUV tool sales require export-license approval for certain destinations. Permission to use these chokepoint capabilities is genuinely conditional. The conditions reflect both commercial and national-security gatekeeping."
    },
    "Regulatory Posture": {
      "value": "Conditional",
      "memo": "TSMC and ASML face conditional regulatory requirements through export controls, foreign-investment screening, and industrial policy.",
