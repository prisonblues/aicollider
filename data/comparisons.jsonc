      },
      {
        "row": "Substitutability",
        "type": "tension",
        "title": "Technical optionality is not always economic optionality",
        "commentary": "Apple and OpenAI/Microsoft both face expensive switching in parts of the stack, while Google is locked into its custom path. Avoiding one supplier can still create switching cost elsewhere."
      }
    ],
    "analysis": {
      "same": "All three are attempts to avoid being trapped by another layer of the AI stack while still using closed, hosted frontier capabilities.",
      "different": "Apple preserves optionality through multi-provider model routing and OS distribution, Google internalizes control through custom infrastructure, and OpenAI/Microsoft remains concentrated around a preferred-partner contract.",
      "impact": "The consequence is that bargaining power depends less on model quality alone than on who owns routing, compute, and the default customer surface."
    }
  },
