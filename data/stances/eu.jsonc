{
  "id": "eu",
  "name": "EU",
  "desc": "Coherent governance posture: conditional rights, extraterritorial reach, controlled residency, transparency mandates, shared value, and project-level sovereignty all push toward managed architecture.",
  "picks": {
    "Capability Class": {
      "value": "Frontier",
      "memo": "EU governance targets frontier systems where transparency, accountability, and risk management matter most.",
      "detail": "The AI Act's tiered approach focuses obligations on high-risk and general-purpose AI systems. Frontier models trigger the most demanding compliance requirements including risk assessments and incident reporting. This regulatory focus shapes which systems are practically deployable in EU markets. The governance framework assumes frontier capability is the primary object of concern."
    },
    "Domain Breadth": {
      "value": "Multi-domain",
      "memo": "EU rules apply extraterritorially across domains, requiring compliance wherever AI systems affect EU subjects or markets.",
      "detail": "The AI Act covers AI systems across all sectors that affect EU residents. Sector-specific rules in finance, healthcare, and employment add layered obligations. Multi-domain breadth means compliance teams must address diverse regulatory requirements simultaneously. The extraterritorial scope extends these obligations to non-EU providers serving EU markets."
    },
    "Capability Trajectory": {
      "value": "Incremental",
      "memo": "Conditional rights and compliance burdens slow capability deployment toward governable, incremental progress.",
      "detail": "Mandatory risk assessments and conformity procedures add deployment lag for new capabilities. Each capability increment triggers fresh compliance evaluation before market release. This creates incremental deployment cadence even when underlying capability advances rapidly. The regulatory friction is intentional, trading speed for governance resilience."
    },
    "Research Automation": {
      "value": "Human-led",
      "memo": "EU AI research remains human-led, with automated research loops constrained by transparency and oversight requirements.",
      "detail": "Regulatory emphasis on human oversight and explainability favors human-directed research programs. Automated research loops face scrutiny under risk-management and transparency obligations. European AI labs operate with more conservative deployment practices than US counterparts. The human-led posture aligns with the governance framework's emphasis on accountability."
    },
    "Unhobbling": {
      "value": "Tool-call enabled",
      "memo": "EU-deployed AI systems access bounded tools within permission frameworks mandated by the AI Act's risk tiers.",
      "detail": "Tool access in EU deployments requires documented risk assessment and human oversight mechanisms. This limits unhobbling to structured, permission-gated tool interactions rather than open-ended agency. The regulatory framework discourages agentic autonomy in high-risk contexts. Tool-call enablement is the practical ceiling for most compliant EU deployments."
    },
    "Replication Scale": {
      "value": "Many copies",
      "memo": "EU-market AI serves many users across member states but faces deployment constraints that limit population-scale spread.",
      "detail": "AI services reach millions of EU users through platform deployments. Compliance requirements create deployment friction that constrains some use cases. The scale is substantial but moderated by regulatory gatekeeping compared to the US. Many copies operate under documented risk-management frameworks."
    },
    "Operating Speed": {
      "value": "Human-speed",
      "memo": "EU oversight requirements keep AI deployment at human-reviewable speed, with compliance checks gating fast operation.",
      "detail": "Human oversight mandates in high-risk systems require reviewable decision pacing. Automated decisions affecting individuals must allow meaningful human intervention. This governance requirement constrains operating speed to human-compatible levels. The trade-off favors accountability and rights protection over throughput."
    },
    "Physical World Extension": {
      "value": "Cognitive-only",
      "memo": "EU AI regulation focuses on cognitive systems; physical-world AI faces additional product-safety and machinery directive constraints.",
      "detail": "Most EU AI deployment remains cognitive: analysis, content, and decision support. Robotic and physical AI triggers additional regulatory layers under machinery and product-safety directives. This regulatory stacking discourages rapid physical-world AI extension. The cognitive-only default reflects both market maturity and regulatory complexity."
    },
    "Role": {
      "value": "Assistant",
      "memo": "EU regulatory posture favors AI as an assistant producing reviewable support, not an autonomous agent owning outcomes.",
      "detail": "Human oversight requirements push AI toward the assistant role rather than autonomous operation. High-risk AI must allow meaningful human review before consequential decisions take effect. This regulatory preference shapes product design toward advisory rather than agentic configurations. The assistant role is a governance choice embedded in the legal framework."
    },
    "Actuation": {
      "value": "Informational",
      "memo": "EU AI systems predominantly provide informational outputs with human intermediation required before consequential action.",
      "detail": "Regulatory oversight requirements insert human decision-makers between AI analysis and real-world action. This limits the actuation channel to informational outputs that humans then act upon. Automated decision-making affecting individuals requires specific legal bases under GDPR. The informational actuation default is a direct consequence of the governance framework."
    },
    "Autonomy": {
      "value": "Human-in-loop",
      "memo": "EU AI governance mandates human-in-the-loop oversight for high-risk systems, preserving approval before consequential steps.",
      "detail": "The AI Act requires effective human oversight proportionate to system risk. High-risk applications must allow operators to override or reverse AI decisions. This creates a structural preference for human-in-loop rather than human-on-loop operation. The mandate applies regardless of the deployer's own risk appetite."
    },
    "Delegated Authority": {
      "value": "Recommend only",
      "memo": "EU rules constrain AI to recommending rather than binding, requiring human intermediation for consequential decisions.",
      "detail": "Automated individual decision-making faces restrictions under GDPR Article 22 and the AI Act. AI systems can analyze, rank, and recommend but should not bind principals without human approval. This recommend-only posture is legally mandated rather than commercially chosen. It preserves individual rights at the cost of automation speed."
    },
    "Tool Access": {
      "value": "Gated tools",
      "memo": "EU AI tool access operates through documented permission gates with risk assessment and audit requirements.",
      "detail": "Tool integrations for high-risk AI require documented risk management and monitoring. Permission gates must be auditable and proportionate to the processing activity. This creates a structured tool-access environment compared to the US's more permissive defaults. Gated tools are the practical ceiling for compliant EU AI deployments."
    },
    "Response / Intervention Capability": {
      "value": "Defined escalation",
      "memo": "EU AI governance requires defined escalation paths with documented incident-response procedures for high-risk systems.",
      "detail": "The AI Act mandates serious incident reporting to national competent authorities. Deployers must establish documented procedures for handling system failures and harmful outputs. Defined escalation is a legal requirement rather than a best-practice recommendation. This creates a more structured response capability than the US best-efforts default."
    },
    "Command Actor": {
      "value": "State/coalition",
      "memo": "EU AI governance is state- and coalition-level, with regulatory authority vesting in member states and EU institutions.",
      "detail": "The AI Act creates a governance framework where EU institutions and member-state authorities hold command. National competent authorities supervise compliance within their jurisdictions. The European AI Board coordinates cross-border governance matters. This coalition command structure contrasts with the US's enterprise-level command default."
    },
    "Decision Tempo": {
      "value": "Product cycle",
      "memo": "EU AI deployment follows product-cycle tempo, with compliance assessments gating release schedules rather than crisis response.",
      "detail": "Conformity assessments and risk evaluations add time to product release cycles. The regulatory process operates on administrative rather than crisis timelines. This product-cycle tempo ensures governance keeps pace with deployment but slows innovation. Providers must build compliance into their development schedules."
    },
    "Tradeoff Authority": {
      "value": "Safety body",
      "memo": "EU AI tradeoff authority sits with safety and regulatory bodies rather than product teams, mandating external review.",
      "detail": "National competent authorities and the European AI Board hold ultimate authority over safety-speed tradeoffs. Product teams cannot unilaterally decide to ship capability that crosses regulatory thresholds. This external tradeoff authority contrasts with the US product-team default. It slows deployment but ensures externalities are addressed before market release."
    },
    "Permission": {
      "value": "Conditional",
      "memo": "EU training permission is conditional on compliance with copyright, GDPR, and AI Act transparency requirements.",
      "detail": "The text and data mining exception requires rights-holder opt-out mechanisms for commercial use. GDPR restricts processing of personal data for AI training without lawful basis. AI Act transparency obligations add further conditions on training data documentation. Permission exists but is heavily conditioned compared to the US broad default."
    },
    "Regulatory Posture": {
      "value": "Conditional",
      "memo": "The EU regulatory posture conditions AI deployment on risk classification, conformity assessment, and ongoing compliance.",
      "detail": "The AI Act creates a risk-based framework with prohibited, high-risk, and general-purpose categories. Each category carries specific obligations from outright bans to documentation and monitoring requirements. Conditional deployment means capability is permitted only when compliance conditions are met. This is a fundamentally different posture from US permissive-by-default."
    },
    "Data Availability": {
      "value": "Licensed",
      "memo": "EU data for AI training is available primarily through licensing, with opt-out rights and GDPR constraints limiting open scraping.",
      "detail": "Rights-holder opt-out mechanisms and GDPR consent requirements create a licensed-data environment. Open web scraping faces legal challenges from copyright and data protection enforcement. This forces training data acquisition through negotiated licensing arrangements. The licensed-data posture increases cost but improves provenance and accountability."
    },
    "Provenance": {
      "value": "Verifiable",
      "memo": "EU transparency requirements push toward verifiable data provenance with documented training data sources and processing records.",
      "detail": "The AI Act requires general-purpose AI providers to document training data including copyright compliance. GDPR mandates records of processing activities for personal data used in training. These requirements create a verifiable provenance chain from source to training. Verifiability is a regulatory mandate rather than a market-driven choice."
    },
    "Model-Weight Rights": {
      "value": "Hosted only",
      "memo": "EU-deployed AI is predominantly hosted-only, with model weights controlled by providers behind API interfaces.",
      "detail": "Most EU AI deployment accesses models through cloud APIs rather than local weight deployment. The hosted-only model keeps weights under provider control and simplifies compliance monitoring. Open-weight deployment within the EU faces additional obligations under the AI Act. The hosted-only default aligns with the governance posture's emphasis on provider accountability."
    },
    "Territory": {
      "value": "Extraterritorial",
      "memo": "EU AI regulation applies extraterritorially, reaching any AI system whose outputs affect EU residents or markets.",
      "detail": "The AI Act follows the GDPR's extraterritorial reach model. Non-EU providers must comply when their systems produce effects within the EU. This creates compliance obligations for US and Asian AI companies serving EU markets. Extraterritorial jurisdiction is the EU's primary mechanism for governing globally deployed AI."
    },
    "Data Subject Exposure": {
      "value": "Ordinary personal data",
      "memo": "EU AI deployments commonly process ordinary personal data, triggering GDPR's full suite of data-subject rights and obligations.",
      "detail": "GDPR applies to any AI processing that involves identified or identifiable individuals. This triggers rights to access, rectification, erasure, and explanation for automated decisions. Personal data exposure is the primary regulatory trigger in the EU framework. Even ordinary personal data activates constraints that US deployments largely avoid."
    },
    "Data Sensitivity": {
      "value": "Sensitive/regulated",
      "memo": "EU data governance treats many AI use cases as involving sensitive or regulated data, triggering heightened protection obligations.",
      "detail": "Special category data under GDPR and sector-specific regulations create heightened sensitivity classifications. Healthcare, biometric, and employment data frequently involved in AI trigger additional safeguards. The sensitive-data default raises compliance costs and constrains processing options. This classification reflects the EU's precautionary approach to data governance."
    },
    "Control Exposure": {
      "value": "No control issue",
      "memo": "Most EU commercial AI deployment sits outside export-control triggers, with dual-use concerns handled through separate regimes.",
      "detail": "EU dual-use export controls apply to specific technologies but most commercial AI is unaffected. The primary regulatory burden comes from the AI Act and GDPR rather than export controls. Control exposure becomes relevant for frontier model transfers and defense applications. For standard commercial deployment, export controls are not the binding constraint."
    },
    "Processing Mode": {
      "value": "Inference",
      "memo": "EU AI deployment emphasizes inference-time use of externally trained models rather than domestic large-scale training.",
      "detail": "European enterprises predominantly consume AI through API inference rather than training their own models. Limited domestic compute capacity and restrictive data rules discourage large-scale training within the EU. This inference-centric mode reduces data-entanglement risk but increases dependency on external providers. The processing-mode default reflects both regulatory and infrastructure realities."
    },
    "Derivation": {
      "value": "Direct output",
      "memo": "EU AI systems produce direct outputs under documented processing purposes rather than recursive derivation chains.",
      "detail": "GDPR's purpose limitation principle constrains how AI outputs can be reused and combined. Recursive derivation chains face scrutiny under data protection impact assessments. This limits the derived-value chains that US providers build from interaction data. Direct output is the cleanest compliance posture under EU data governance."
    },
    "Retention / Persistence": {
      "value": "Deletion-required",
      "memo": "EU data governance mandates deletion when processing purposes are fulfilled, constraining persistent data retention.",
      "detail": "GDPR's storage limitation principle requires data deletion when processing purposes expire. The right to erasure creates individual deletion obligations that conflict with model training persistence. This deletion-required posture contrasts sharply with US weight-entangled retention. The legal requirement creates practical tension with neural-network training's irreversible nature."
    },
    "Execution / Residency Environment": {
      "value": "Sovereign",
      "memo": "EU data sovereignty requirements push AI execution toward controlled European residency environments.",
      "detail": "Data-localization preferences and Schrems II transfer restrictions favor EU-resident infrastructure. Cloud providers offer EU-only regions to meet sovereign residency requirements. This creates a sovereign execution environment distinct from the US public-cloud default. The sovereignty push reflects both data-protection and strategic-autonomy objectives."
    },
    "Boundary": {
      "value": "Dedicated tenant",
      "memo": "EU compliance and data-sovereignty requirements push AI deployments toward dedicated tenancy rather than shared infrastructure.",
      "detail": "Data protection requirements favor logical or physical isolation between tenants. Dedicated tenancy provides clearer compliance boundaries for data residency and access control. This contrasts with the US shared-boundary default driven by cost optimization. The dedicated-tenant preference adds cost but simplifies regulatory compliance."
    },
    "Deployment Surface": {
      "value": "Restricted users",
