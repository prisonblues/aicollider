{
  "id": "uk-training",
  "name": "UK LLM training",
  "desc": "Not a compute problem: the statement 'you would not train an LLM in the UK' reflects a jurisdictional data-availability and regulatory-posture constraint, not merely a shortage of GPUs.",
  "picks": {
    "Capability Class": {
      "value": "Frontier",
      "memo": "The UK training constraint matters because it affects whether frontier-scale training can occur under UK jurisdiction.",
      "detail": "The constraint is specifically about frontier-scale training that requires internet-scale data. Smaller models or domain-specific training can navigate UK licensing requirements more easily. The frontier focus is where the data-availability constraint becomes binding. UK compute limitations compound the data constraint but are not the primary issue."
    },
    "Domain Breadth": {
      "value": "General",
      "memo": "General-purpose LLM training requires broad multi-domain data, which is where UK copyright protections create maximum friction.",
      "detail": "Frontier LLMs need training data spanning all text domains to achieve general capability. UK copyright applies across domains without exception, creating friction for every data category. Domain-specific models could negotiate focused licensing but general-purpose models cannot. The general-breadth requirement intersects most severely with UK rights-holder protections."
    },
    "Capability Trajectory": {
      "value": "Incremental",
      "memo": "UK regulatory uncertainty forces cautious, incremental approaches to AI capability development within UK jurisdiction.",
      "detail": "Legal uncertainty around training rights discourages bold UK-based training investments. Companies proceed with small, cautious steps rather than committing to large training runs. This incremental trajectory is imposed by the regulatory environment, not technical limitations. Faster trajectories are available but require training outside UK jurisdiction."
    },
    "Research Automation": {
      "value": "AI-assisted",
      "memo": "UK AI research uses AI tools within human-directed programs, limited by compute access rather than research methodology.",
      "detail": "UK researchers use frontier models from US providers to assist research. The AI-assistance level is constrained by access to compute and training infrastructure. Human-led research direction reflects both institutional culture and practical constraints. The research-automation level is a consequence of the infrastructure constraint."
    },
    "Unhobbling": {
      "value": "Tool-call enabled",
      "memo": "UK-based AI development can build tool-call-enabled systems but the training constraint limits the base model capability available.",
      "detail": "UK developers can build tool integrations using models trained elsewhere. The unhobbling constraint is at the base model level, not the application layer. Tool-call enabling on externally trained models is straightforward. The real limitation is that the UK cannot produce the underlying models domestically."
    },
    "Replication Scale": {
      "value": "Many copies",
      "memo": "UK-based AI serves many users through deployments of externally trained models, not domestically trained ones.",
      "detail": "UK enterprises deploy many copies of AI systems using models trained in more permissive jurisdictions. The replication scale reflects deployment of imported models rather than UK-trained capability. Many-copies deployment is viable because inference, unlike training, does not face data-rights constraints. The training constraint does not limit deployment scale."
    },
    "Operating Speed": {
      "value": "Faster-than-human",
      "memo": "UK AI deployments operate at the same speed as elsewhere since inference performance is hardware-limited, not jurisdiction-limited.",
      "detail": "Cloud-served inference operates identically regardless of where the model was trained. No UK-specific constraint affects operating speed at the deployment layer. The training constraint is about data access, not about deployment performance. Faster-than-human operation is available for UK deployments using externally trained models."
    },
    "Physical World Extension": {
      "value": "Cognitive-only",
      "memo": "UK AI development focuses on cognitive applications, with the training constraint primarily affecting language and knowledge models.",
      "detail": "The copyright and data-availability constraint is most binding for text-based LLM training. Physical-world AI faces different regulatory constraints through separate frameworks. Cognitive-only focus reflects both the nature of the constraint and the UK's services-economy structure. The training limitation is primarily about language models, not robotics."
    },
    "Role": {
      "value": "Assistant",
      "memo": "UK-deployed AI systems serve assistant roles using externally trained models, with the training constraint limiting domestic model capability.",
      "detail": "Enterprise AI in the UK operates as assistants within business workflows. The assistant role can be fulfilled using models trained outside UK jurisdiction. The training constraint affects who can build the underlying model, not the deployment role. UK enterprises are consumers rather than producers of base model capability."
    },
    "Actuation": {
      "value": "Digital action",
